# ============================================
# CDN Panel — Environment Variables
# ============================================

# JWT Secret Key (gunakan string acak yang panjang di production)
JWT_SECRET=cdn-panel-super-secret-key-change-in-production

# Upstash Redis (untuk rate limiting — production recommended)
# Dapatkan dari https://console.upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob Storage (opsional — jika tidak di-set, file disimpan lokal di public/uploads/)
# Dapatkan token dari https://vercel.com/dashboard/stores/blob
# BLOB_READ_WRITE_TOKEN=

# Supabase (opsional — untuk production, database lebih stabil)
# Dapatkan dari https://supabase.com/dashboard/project/<project-id>/settings/api
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Notes:
# - JWT_SECRET wajib di-set dengan string acak panjang di production
# - UPSTASH_REDIS_* dibutuhkan untuk rate limiting production. Tanpa ini, rate limiter fallback ke allow-all.
# - BLOB_READ_WRITE_TOKEN tidak wajib. Tanpa token, file disimpan di public/uploads/
# - Jangan commit .env ke VCS
